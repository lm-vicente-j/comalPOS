generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"

}

datasource db {
  provider = "postgresql"
}

model bill {
  id            Int      @id @default(autoincrement())
  description   String?  @db.Text
  amount        Decimal  @db.Decimal
  category      String?  @db.VarChar(50)
  date          DateTime? @db.Date
  registered_by Int
  users         users    @relation(fields: [registered_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model customer {
  id              Int       @id @default(autoincrement())
  customerName    String?   @db.VarChar(100)
  phone           String?   @db.VarChar(20)
  alias           String?   @db.VarChar(30)
  lastConsumption DateTime? @db.Date
  currentBalance  Decimal   @db.Decimal
  registeredDate  DateTime? @db.Date
  debtors         debtors[]
  sales           sales[]
}

model debtors {
  id         Int      @id @default(autoincrement())
  saleID     Int
  customerID Int
  amount     Decimal  @db.Decimal
  status     String?  @db.VarChar(20)
  customer   customer @relation(fields: [customerID], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales      sales    @relation(fields: [saleID], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerID, status])
}

model products {
  id         Int          @id @default(autoincrement())
  name       String?      @db.VarChar(40)
  price      Decimal      @db.Decimal
  recipes    recipes[]
  sale_items sale_items[]
}

model recipes {
  productID    Int
  supplyID     Int
  quantityUsed Decimal? @db.Decimal
  products     products @relation(fields: [productID], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplies     supplies @relation(fields: [supplyID], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([productID, supplyID])
}

model salary {
  id      Int       @id @default(autoincrement())
  userID  Int
  amount  Decimal   @db.Decimal
  payDate DateTime? @db.Date
  period  String?   @db.VarChar(50)
  users   users     @relation(fields: [userID], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sale_items {
  id        Int      @id @default(autoincrement())
  saleID    Int
  productID Int
  quantity  Int
  unitPrice Decimal  @db.Decimal
  subtotal  Decimal  @db.Decimal
  products  products @relation(fields: [productID], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales     sales    @relation(fields: [saleID], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([saleID])
  @@index([productID])
}

model sales {
  id          Int          @id @default(autoincrement())
  total       Decimal?     @db.Decimal
  status      String?      @db.VarChar(20)
  source_type String?      @db.VarChar(30)
  customerID  Int?
  placedBy    Int
  createdAt   DateTime     @default(now()) @db.Timestamp
  debtors     debtors[]
  sale_items  sale_items[]
  customer    customer?     @relation(fields: [customerID], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users        @relation(fields: [placedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerID, createdAt])
}

model supplies {
  id           Int       @id @default(autoincrement())
  name         String?   @db.VarChar(40)
  measureUnit  String?   @db.VarChar(30)
  currentStock Decimal   @db.Decimal
  unitCost     Decimal   @default(0) @db.Decimal
  recipes      recipes[]
}

model users {
  id       Int      @id @default(autoincrement())
  email    String?  @db.VarChar(150)
  name     String?  @db.VarChar(50)
  username String?  @db.VarChar(50)
  pin      String?  @db.VarChar(255)
  password String?  @db.VarChar(255)
  role     String?  @db.VarChar(40)
  active   Boolean?
  bill     bill[]
  salary   salary[]
  sales    sales[]
}